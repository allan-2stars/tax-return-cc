# ── App ────────────────────────────────────────────────────────
ENVIRONMENT=development               # development | production | test

# ── Security ───────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////data/db/tax_return.db
# PostgreSQL (future): postgresql+asyncpg://user:pass@db:5432/tax

# ── Storage ────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_PATH=/data/documents
# S3 (future):
# S3_BUCKET=
# S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── AI ─────────────────────────────────────────────────────────
AI_PROVIDER=claude                    # claude | openai | ollama
ANTHROPIC_API_KEY=
AI_TIMEOUT_SECONDS=15
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# ── Auth ───────────────────────────────────────────────────────
# Generate via: make shell-be, then:
# python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
APP_PASSWORD_HASH=
SESSION_MAX_AGE_DAYS=7
UNLOCK_SESSION_MINUTES=30

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=https://taxcc.signpega.com,http://127.0.0.1:3060

# ── Features ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
EXPORT_RETENTION_HOURS=24
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
